// izvuci cijene stavke %apartman%
SELECT
  r.id,
  r.date,
  json_extract(item.value, '$.description') AS description,
  json_extract(item.value, '$.total_price') AS price
FROM receipts AS r
JOIN json_each(r.data_json, '$.items') AS item
WHERE LOWER(json_extract(item.value, '$.description')) LIKE '%apartman%';

